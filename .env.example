# Leviio environment variables
# Copy this file to `.env.local` and fill in values. `.env.local` is git-ignored.
#
# NOTE: Variables prefixed NEXT_PUBLIC_ are bundled into the browser and are
# therefore NOT secret. Real secrets (service-role keys, payment secrets) must
# NEVER use the NEXT_PUBLIC_ prefix.

# --- Supabase (database + auth) ---
# From Supabase dashboard → Project Settings → API.
# When these two NEXT_PUBLIC_ vars are set, the app switches from localStorage
# demo mode to the real Supabase database automatically (see src/lib/store.tsx).
# Also run supabase/schema.sql, and turn OFF "Confirm email" in
# Authentication → Providers → Email so signups log in immediately.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the browser. Used by trusted server actions/webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Public site URL (used for OG tags, auth redirects, share links) ---
NEXT_PUBLIC_SITE_URL=https://leviio.com

# --- Optional: split the client portal onto its own subdomain (Option A) ---
# Set BOTH to route the creator app and client portal to separate hosts. When
# either is empty (e.g. local dev), the app runs on a single domain as before.
# The client portal is then served only from PORTAL_HOST; the creator app/
# dashboard only from APP_HOST. Add both hosts to Supabase → Auth → URL
# Configuration → Redirect URLs, and point both subdomains at this deployment.
NEXT_PUBLIC_APP_HOST=leviio.com
NEXT_PUBLIC_PORTAL_HOST=portal.leviio.com

# --- Razorpay (payments) ---
# From Razorpay Dashboard → Settings → API Keys. Use TEST keys (rzp_test_) with
# Razorpay's test cards before switching to LIVE keys (rzp_live_) for real money.
# When both are set, the storefront checkout and the Pro upgrade charge for real.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
# Server-only secret — never expose to the browser (no NEXT_PUBLIC_ prefix).
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook signing secret (Razorpay Dashboard → Settings → Webhooks). Enables the
# /api/razorpay/webhook safety net that records orders even if the buyer leaves.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Platform admin (god-mode panel at /admin) ---
# Comma-separated emails allowed into the platform admin panel. Server-only.
# Admin access = being logged in as a creator account whose email is listed here
# (no separate admin password — it's that account's own login password).
ADMIN_EMAILS=you@leviio.com

# --- Anthropic / Claude (AI diet-plan generator) ---
# From console.anthropic.com → API Keys. Server-only secret (no NEXT_PUBLIC_).
# When set, the "Generate with AI" button in the Diet Planner becomes active.
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Resend (transactional email) ---
# From resend.com → API Keys. Powers order receipts, booking + portal invites.
# EMAIL_FROM must use a domain you've verified in Resend (or omit to use the
# Resend test sender, which only delivers to your own account email).
RESEND_API_KEY=re_xxx
EMAIL_FROM=Leviio <noreply@leviio.com>
